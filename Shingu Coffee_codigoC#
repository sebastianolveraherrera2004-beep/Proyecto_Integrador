    public static bool EsNumeroEntero(string dato)
    {
        if (dato == null || dato.Trim().Length == 0) return false;
        foreach (char c in dato)
        {
            if (!Char.IsDigit(c)) return false;
        }
        return true;
    }

    public static bool EsNumeroDouble(string dato)
    {
        if (dato == null || dato.Trim().Length == 0) return false;
        bool punto = false;
        bool digito = false;
        foreach (char c in dato)
        {
            if (Char.IsDigit(c))
            {
                digito = true;
            }
            else if (c == '.' && !punto)
            {
                punto = true;
            }
            else
            {
                return false;
            }
        }
        return digito;
    }

    public static bool EvaluarNumerico(string dato, int tipo)
    {
        bool valido = false;
        switch (tipo)
        {
            case 1:
                valido = EsNumeroEntero(dato);
                break;
            case 2:
                valido = EsNumeroDouble(dato);
                break;
        }
        return valido;
    }

