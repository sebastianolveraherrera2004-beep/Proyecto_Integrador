    public static double SubTotalTicket(string[,] mticket)
    {
        double subtotal = 0;
        int pos = ObtenerUltimaPosicion(mticket);
        for (int ciclo = 0; ciclo <= pos; ciclo++) subtotal += double.Parse(TotalProducto(mticket[ciclo, 2], mticket[ciclo, 3]));
        return subtotal;
    }

    public static double IvaTicket(string[,] mticket, string[,] mproductos)
    {
        double ivatotal = 0;
        int pos = ObtenerUltimaPosicion(mticket);
        for (int ciclo = 0; ciclo <= pos; ciclo++)
        {
            string codigo = mticket[ciclo, 0];
            double iva = ObtenerIva(codigo, mproductos);
            if (iva != 0)
            {
                double precio = double.Parse(mticket[ciclo, 2]);
                double cantidad = double.Parse(mticket[ciclo, 3]);
                ivatotal += ((precio * cantidad) * (iva / 100));
            }
        }
        return ivatotal;
    }

    public static double TotalTicket(string[,] mticket, string[,] mproductos)
    {
        double total = SubTotalTicket(mticket);
        if (total > 0) total = IvaTicket(mticket, mproductos) + total;
        return total;
    }

