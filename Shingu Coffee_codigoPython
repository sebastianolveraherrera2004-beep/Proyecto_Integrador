def DescontarStock(mproductos, codigo, cantidad):
    posp = ExisteProducto(codigo.strip(), mproductos)
    if posp == -1:
        return -2
    stock = int(mproductos[posp][3])
    if stock == 0:
        return 0
    if cantidad > stock:
        return -1
    mproductos[posp][3] = str(stock - cantidad)
    return 1


