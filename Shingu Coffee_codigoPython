def SubTotalTicket(mticket):
    subtotal = 0
    pos = ObtenerUltimaPosicion(mticket)
    for ciclo in range(pos + 1):
        subtotal = subtotal + float(TotalProducto(mticket[ciclo][2], mticket[ciclo][3]))
