def IvaTicket(mticket, mproductos):
    ivatotal = 0
    pos = ObtenerUltimaPosicion(mticket)
    for ciclo in range(pos + 1):
        codigo = mticket[ciclo][0]
        iva = ObtenerIva(codigo, mproductos)
        if iva != 0:
            precio = float(mticket[ciclo][2])
            cantidad = float(mticket[ciclo][3])
            ivatotal = ivatotal + ((precio * cantidad) * (iva / 100))
    return ivatotal


def TotalTicket(mticket, mproductos):
    total = SubTotalTicket(mticket)
    if total > 0:
        total = IvaTicket(mticket, mproductos) + total
    return total


