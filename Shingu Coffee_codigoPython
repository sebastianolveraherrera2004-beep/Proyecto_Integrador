def ExisteProducto(codigo, vproductos):
    enc = -1
    pos = 0
    tam = len(vproductos)
    for ciclo in range(tam):
        if vproductos[ciclo][0] == codigo.strip():
            enc = pos
        pos += 1
    return enc


