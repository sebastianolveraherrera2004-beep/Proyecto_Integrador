def EsNumeroEntero(dato):
    if dato is None or dato.strip() == "":
        return False
    for c in dato:
        if not c.isdigit():
            return False
    return True


def EsNumeroDouble(dato):
    if dato is None or dato.strip() == "":
        return False
    punto = False
    digito = False
    for c in dato:
        if c.isdigit():
            digito = True
        elif c == "." and not punto:
            punto = True
        else:
            return False
    return digito


def EvaluarNumerico(dato, tipo):
    valido = False
    if tipo == 1:
        valido = EsNumeroEntero(dato)
    elif tipo == 2:
        valido = EsNumeroDouble(dato)
    return valido


def Dialogo(texto):
    print(texto + " : ")
    return input()


def Leer(texto):
    cadena = Dialogo(texto)
    if cadena is not None:
        cadena = cadena.strip()
        if cadena == "":
            cadena = None
    return cadena


def LeerValidado(texto_dialogo, tipo_dato):
    while True:
        cadena = Dialogo(texto_dialogo)
        if cadena is not None:
            cadena = cadena.strip()
        if cadena is not None and cadena != "" and EvaluarNumerico(cadena, tipo_dato):
            return cadena
        print("Dato incorrecto. Intente nuevamente.")


